<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/search_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pro_header_footer">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/search_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/pro_header_footer"
        app:title="Search in Project"
        app:titleTextColor="@color/pro_on_surface"
        app:navigationIcon="?attr/homeAsUpIndicator"
        android:elevation="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:background="@color/pro_surface"
            android:padding="4dp">

            <EditText
                android:id="@+id/etGlobalSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search for code..."
                android:textColor="@color/pro_on_surface"
                android:textColorHint="@color/pro_on_surface_dim"
                android:background="@null"
                android:padding="12dp"
                android:inputType="text"/>

            <ImageButton
                android:id="@+id/btnDoGlobalSearch"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/pro_accent"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSearchResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Results: 0"
            android:textColor="@color/pro_on_surface_dim"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSearchResults"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>

</LinearLayout>