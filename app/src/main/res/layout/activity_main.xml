<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_background">

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/pro_header_footer"
            app:titleTextColor="@color/pro_on_surface"
            android:theme="@style/ThemeOverlay.AppCompat.DayNight.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            android:elevation="4dp"/>

        <!-- Tab Bar for Open Files -->
        <HorizontalScrollView
            android:id="@+id/hsvTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/pro_surface"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/llTabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Tabs will be added here dynamically -->
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Filename and Status Bar (Condensed) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/pro_header_footer"
            android:padding="4dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvCurrentFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_filename"
                android:textColor="@color/pro_on_surface"
                android:textSize="12sp"
                android:layout_marginStart="12dp"
                android:typeface="monospace"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_status"
                android:textColor="@color/pro_on_surface_dim"
                android:textSize="10sp"
                android:layout_marginEnd="12dp"
                android:typeface="monospace"/>
        </LinearLayout>

        <!-- Search & Replace Bar (Hidden by default) -->
        <LinearLayout
            android:id="@+id/llSearchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/pro_surface"
            android:padding="8dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_search"
                    android:textColor="@color/pro_on_surface"
                    android:textColorHint="@color/pro_on_surface_dim"
                    android:textSize="14sp"
                    android:background="@color/pro_header_footer"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp"/>
                <ImageButton
                    android:id="@+id/btnFindNext"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="@string/desc_find_next"
                    app:tint="@color/pro_on_surface"/>
                <ImageButton
                    android:id="@+id/btnCloseSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="@string/desc_close_search"
                    app:tint="@color/pro_on_surface"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <EditText
                    android:id="@+id/etReplace"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/hint_replace"
                    android:textColor="@color/pro_on_surface"
                    android:textColorHint="@color/pro_on_surface_dim"
                    android:textSize="14sp"
                    android:background="@color/pro_header_footer"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp"/>
                    <Button
                        android:id="@+id/btnReplaceAll"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/btn_replace_all"
                        android:textSize="10sp"
                        android:textColor="@color/pro_header_footer"
                        android:backgroundTint="@color/pro_accent"
                        style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Quick Access Snippet Bar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/pro_header_footer"
            android:scrollbars="none"
            android:padding="4dp">
            <LinearLayout
                android:id="@+id/llSnippets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Snippets will be added here -->
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvLineNumbers"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@color/editor_line_numbers_bg"
                    android:gravity="top|end"
                    android:paddingTop="12dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="1"
                    android:textColor="@color/editor_line_numbers_text"
                    android:textSize="14sp"
                    android:typeface="monospace" />

                <View
                    android:id="@+id/line_divider"
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/editor_line_numbers_bg" />

                <EditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/editor_background"
                    android:gravity="top"
                    android:hint="@string/hint_code_editor"
                    android:textColorHint="@color/pro_on_surface_dim"
                    android:inputType="textMultiLine|textNoSuggestions|textVisiblePassword"
                    android:padding="12dp"
                    android:scrollbars="vertical"
                    android:scrollHorizontally="true"
                    android:textColor="@color/editor_text"
                    android:textSize="14sp"
                    android:typeface="monospace" />
            </LinearLayout>

            <!-- Live Preview Split Screen -->
            <LinearLayout
                android:id="@+id/llLivePreview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.8"
                android:orientation="vertical"
                android:background="@color/pro_surface"
                android:visibility="gone">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/pro_accent"/>
                <android.webkit.WebView
                    android:id="@+id/wvPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>
        </LinearLayout>

        <!-- Debug / Console Output Panel -->
        <TextView
            android:id="@+id/tvDebugInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="120dp"
            android:background="@color/debug_error_bg"
            android:padding="10dp"
            android:text="@string/default_console_output"
            android:textColor="@color/debug_error_text"
            android:textSize="12sp"
            android:visibility="gone"
            android:typeface="monospace" />

        <!-- Bottom Action Bar -->
        <HorizontalScrollView
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/pro_header_footer">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <!-- File Search, Save, Share Buttons -->
                <ImageButton
                    android:id="@+id/btnOpen"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="@string/desc_open_file"
                    app:tint="@color/pro_on_surface"/>
                <ImageButton
                    android:id="@+id/btnSave"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="@string/desc_save_file"
                    app:tint="@color/pro_on_surface"/>
                <ImageButton
                    android:id="@+id/btnShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="@string/desc_share_file"
                    app:tint="@color/pro_on_surface"/>

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent"/>

                <!-- Dev Tools -->
                <Button
                    android:id="@+id/btnFormat"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_format"
                    android:textSize="10sp"
                    android:textColor="@color/pro_on_surface"
                    android:backgroundTint="@color/pro_surface"
                    android:layout_marginHorizontal="2dp"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btnHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_history"
                    android:textSize="10sp"
                    android:textColor="@color/pro_on_surface"
                    android:backgroundTint="@color/pro_surface"
                    android:layout_marginHorizontal="2dp"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btnSnippets"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_snippets"
                    android:textSize="10sp"
                    android:textColor="@color/pro_on_surface"
                    android:backgroundTint="@color/pro_surface"
                    android:layout_marginHorizontal="2dp"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btnDebug"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_compile"
                    android:textSize="10sp"
                    android:textColor="@color/pro_on_surface"
                    android:backgroundTint="@color/pro_surface"
                    android:layout_marginHorizontal="2dp"
                    style="@style/Widget.MaterialComponents.Button"/>

                <Button
                    android:id="@+id/btnRun"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_run"
                    android:textSize="10sp"
                    android:textColor="@color/pro_header_footer"
                    android:backgroundTint="@color/pro_accent"
                    android:layout_marginHorizontal="2dp"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_view_container"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/pro_header_footer"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <!-- Custom Header with Explorer -->
        <include layout="@layout/nav_header_main" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/pro_on_surface_dim"
            android:alpha="0.2"/>

        <!-- Menu Items in a ScrollView to prevent overflow -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbarStyle="outsideOverlay">

            <LinearLayout
                android:id="@+id/llCustomMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">
                <!-- Menu items will be added here via Java -->
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>