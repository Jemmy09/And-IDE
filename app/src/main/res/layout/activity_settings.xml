<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pro_header_footer">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/pro_header_footer"
        app:title="Settings"
        app:titleTextColor="@color/pro_on_surface"
        app:navigationIcon="?attr/homeAsUpIndicator"
        android:elevation="4dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:background="@color/pro_header_footer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                app:cardCornerRadius="50dp"
                app:cardBackgroundColor="@color/pro_surface"
                app:cardElevation="4dp">
                <ImageView
                    android:id="@+id/ivProfilePicture"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/pro_on_surface_dim"
                    android:scaleType="centerCrop"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangePicture"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Change Picture"
                android:textColor="@color/pro_accent"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Name"
                app:hintTextColor="@color/pro_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginTop="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pro_on_surface" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Birthday"
                app:hintTextColor="@color/pro_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginTop="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProfileBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pro_on_surface" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Age"
                app:hintTextColor="@color/pro_accent"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginTop="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProfileAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pro_on_surface"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appearance"
                android:textColor="@color/pro_accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swDarkMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editor Dark Mode"
                android:textColor="@color/pro_on_surface"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swAutoSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Auto-Save"
                android:textColor="@color/pro_on_surface"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swShowLineNumbers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show Line Numbers"
                android:textColor="@color/pro_on_surface"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swConfirmDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm on File Delete"
                android:textColor="@color/pro_on_surface"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editor Font Size"
                android:textColor="@color/pro_on_surface_dim"
                android:layout_marginTop="8dp"/>

            <RadioGroup
                android:id="@+id/rgFontSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <RadioButton android:id="@+id/rbFontSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Small" android:textColor="@color/pro_on_surface" />
                <RadioButton android:id="@+id/rbFontMedium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medium" android:textColor="@color/pro_on_surface" android:layout_marginStart="16dp"/>
                <RadioButton android:id="@+id/rbFontBig" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Big" android:textColor="@color/pro_on_surface" android:layout_marginStart="16dp"/>
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Permissions"
                android:textColor="@color/pro_accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swAiFileAccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Allow DDee to Edit Files"
                android:textColor="@color/pro_on_surface"
                app:thumbTint="@color/pro_accent"
                app:trackTint="@color/pro_surface"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enabling this allows DDee to read, write, and debug your project files directly."
                android:textColor="@color/pro_on_surface_dim"
                android:textSize="12sp"
                android:padding="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:padding="14dp"
                android:text="Save All Changes"
                android:textColor="@color/pro_header_footer"
                android:backgroundTint="@color/pro_accent"
                app:cornerRadius="8dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>