<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/tutorial_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pro_header_footer">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/pro_header_footer"
        app:titleTextColor="@color/pro_on_surface"
        app:navigationIcon="?attr/homeAsUpIndicator"
        android:theme="@style/ThemeOverlay.AppCompat.DayNight.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        android:elevation="4dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header Content -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_header"
                android:textColor="@color/pro_accent"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_subtitle"
                android:textColor="@color/pro_on_surface_dim"
                android:textSize="14sp"
                android:layout_marginBottom="32dp"
                android:typeface="monospace"/>

            <!-- Sections -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_1_title"
                android:textColor="@color/pro_on_surface"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_1_text"
                android:textColor="@color/pro_on_surface"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_2_title"
                android:textColor="@color/pro_on_surface"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_2_text"
                android:textColor="@color/pro_on_surface"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_3_title"
                android:textColor="@color/pro_on_surface"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_3_text"
                android:textColor="@color/pro_on_surface"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_4_title"
                android:textColor="@color/pro_on_surface"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_section_4_text"
                android:textColor="@color/pro_on_surface"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="24dp"/>

            <!-- Pro Tips Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/pro_surface"
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_pro_tips_title"
                    android:textColor="@color/pro_accent"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_pro_tips_text"
                    android:textColor="@color/pro_on_surface"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnBackToApp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_lets_build"
                android:textAllCaps="true"
                android:textColor="@color/pro_header_footer"
                android:backgroundTint="@color/pro_accent"
                android:padding="16dp"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_version_footer"
                android:textColor="@color/pro_on_surface_dim"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>